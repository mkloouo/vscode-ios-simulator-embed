{
  "name": "ios-simulator-embed",
  "displayName": "iOS Simulator (streamed panel)",
  "description": "Stream the iOS Simulator into a VS Code webview and forward pointer input (macOS, ScreenCaptureKit).",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ios-simulator-embed.openPanel",
    "onCommand:ios-simulator-embed.stopPanel",
    "onCommand:ios-simulator-embed.listWindows"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ios-simulator-embed.openPanel",
        "title": "iOS Simulator: Open streamed panel"
      },
      {
        "command": "ios-simulator-embed.stopPanel",
        "title": "iOS Simulator: Stop stream"
      },
      {
        "command": "ios-simulator-embed.listWindows",
        "title": "iOS Simulator: List capture windows (debug)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "iOS Simulator Embed",
      "properties": {
        "ios-simulator-embed.targetBundleId": {
          "type": "string",
          "default": "",
          "description": "If set, only windows whose owning bundle ID equals this value are streamed (copy bundleId from “List capture windows” NDJSON). Example: com.apple.iphonesimulator"
        },
        "ios-simulator-embed.simulatorUdid": {
          "type": "string",
          "default": "",
          "description": "Booted simulator UDID for Indigo touch injection (`xcrun simctl list devices | grep Booted`). Leave empty if only one simulator is booted."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:native": "bash native/ios-sim-helper/build.sh"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
